# ─────────────────────────────────────────────────────────
# 시크릿 자리표시자 — 이 파일을 ~/.agent-secrets/hermes.env 로
# 복사한 뒤 실제 값을 입력한다. 실제 값이 든 파일은 절대 git에 넣지 않는다.
#   cp config/hermes.env.example ~/.agent-secrets/hermes.env
#   chmod 600 ~/.agent-secrets/hermes.env
#
# ⚠️ 형식 규칙: 이 파일은 셸 `source`(.)로 읽힌다.
#   - 값 뒤에 인라인 주석을 달지 않는다 (값에 포함돼 버린다)
#   - 실제 파일에는 $HOME 같은 변수 대신 절대경로를 쓴다
# ⚠️ 실제 값은 패스워드 매니저에도 함께 보관한다 (재해 복구 경로)
# ─────────────────────────────────────────────────────────

# Slack Incoming Webhook — #agent-log 채널용
# 발급: Slack 앱 관리 → Incoming Webhooks → #agent-log 대상으로 생성
SLACK_WEBHOOK_URL=

# Claude API (라우팅 정책이 Claude를 쓸 때)
ANTHROPIC_API_KEY=

# pgrep으로 헤르메스 데몬을 찾을 때 쓰는 패턴
HERMES_PATTERN=hermes

# 이 레포의 로컬 절대경로 (예: /Users/you/agent-config)
AGENT_REPO=

# NAS 마운트 지점 (설정하면 heartbeat가 마운트 여부를 매일 검사) 예: /Volumes/NAS
NAS_MOUNT=

# 헤르메스 Slack 봇 토큰 (xoxb-…) — 설정하면 heartbeat가 토큰 유효성을 매일 검사
# ("데몬은 살아있는데 귀머거리" 상태 = 토큰 만료를 잡는 유일한 자동 검사)
HERMES_BOT_TOKEN=
