#!/usr/bin/env python3
"""invest-poll — 실 KIS 잔고(국내+해외) 폴링 + investment_goals.json 조건 평가 → #inv-투자관리 알림.
bin/kis-balance의 KIS REST 로직 재사용(직접 호출, MCP 불필요). 15분 주기(launchd). READ-ONLY(주문 없음).
조건 타입:
  total_change_pct  총자산(국내+해외 KRW) 변동률. threshold_pct(음수=하락/양수=상승), window(day=당일시가대비|tick=직전폴대비)
  position_target   특정 종목 목표가 도달. code, target_price, side(above|below), name
상태: memory/invest_state.json(당일 시가·직전 총자산), 쿨다운: memory/projects/_alert_cooldown.json"""
import json, os, sys, time, datetime, pathlib, importlib.util, importlib.machinery, urllib.request

ROOT = pathlib.Path(__file__).resolve().parent.parent
GOALS_F = ROOT / "memory/investment_goals.json"
STATE_F = ROOT / "memory/invest_state.json"
INV_CHANNEL = "C0B6WRBJE82"  # #inv-투자관리

# kis-balance(하이픈 파일명)를 경로 임포트해 KIS REST 함수 재사용(중복 없이 동기화)
_loader = importlib.machinery.SourceFileLoader("kisbal", str(ROOT / "bin/kis-balance"))
kb = importlib.util.module_from_spec(importlib.util.spec_from_loader("kisbal", _loader))
_loader.exec_module(kb)


def _env(k):
    f = ROOT / ".env"
    if f.exists():
        for line in f.read_text(encoding="utf-8").splitlines():
            if line.startswith(k + "="):
                return line.split("=", 1)[1].strip().strip('"').strip("'")
    return os.environ.get(k)


SLACK_TOKEN = _env("SLACK_BOT_TOKEN")


def slack(text):
    if not SLACK_TOKEN:
        return False
    body = json.dumps({"channel": INV_CHANNEL, "text": text}).encode()
    req = urllib.request.Request("https://slack.com/api/chat.postMessage", data=body, method="POST",
        headers={"Authorization": f"Bearer {SLACK_TOKEN}", "Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=8) as r:
            return json.load(r).get("ok", False)
    except Exception as e:
        print(f"[invest-poll] slack err: {e}", file=sys.stderr)
        return False


def cooldown_ok(alert_id, minutes):
    cd = ROOT / "memory/projects/_alert_cooldown.json"
    data = json.loads(cd.read_text()) if cd.exists() else {}
    last = data.get(alert_id)
    if last:
        try:
            if (datetime.datetime.now() - datetime.datetime.fromisoformat(last)).total_seconds() < minutes * 60:
                return False
        except Exception:
            pass
    data[alert_id] = datetime.datetime.now().isoformat()
    cd.parent.mkdir(parents=True, exist_ok=True)
    cd.write_text(json.dumps(data, indent=2, ensure_ascii=False))
    return True


def _load(p):
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return {}


def kis_price(token, code):
    """KIS 개별 국내종목 현재가(원). 미보유 종목도 조회 가능. 실패 시 0."""
    try:
        j = kb._http("GET", kb.BASE + "/uapi/domestic-stock/v1/quotations/inquire-price",
                     headers=kb._headers(token, "FHKST01010100"),
                     params={"FID_COND_MRKT_DIV_CODE": "J", "FID_INPUT_ISCD": code})
        return kb._num((j.get("output") or {}).get("stck_prpr"))
    except Exception:
        return 0.0


def main():
    if "--test" in sys.argv:
        ok = slack(":bell: [테스트] invest-poll 알림 경로 정상. 실제 알림은 총자산 ±% 또는 종목 목표가 충족 시 발화됩니다.")
        print(f"[invest-poll] test alert sent ok={ok}")
        return 0
    if not kb.APP_KEY:
        print("[invest-poll] KIS not configured, skipping")
        return 0
    try:
        token = kb.get_token()
        dom = kb.domestic(token)
        time.sleep(0.4)
        ovs = kb.overseas(token)
    except Exception as e:
        print(f"[invest-poll] KIS 조회 실패: {e}", file=sys.stderr)
        return 1
    if "error" in dom:
        dom = {"total_eval": 0, "positions": []}
    if "error" in ovs:
        ovs = {"total_eval_krw": 0, "holdings": []}
    total = kb._num(dom.get("total_eval")) + kb._num(ovs.get("total_eval_krw"))

    today = datetime.datetime.now().strftime("%Y-%m-%d")
    st = _load(STATE_F)
    if st.get("day") != today:
        st = {"day": today, "day_open": total, "last_total": total}
    day_open = kb._num(st.get("day_open")) or total
    last_total = kb._num(st.get("last_total")) or total

    goals = _load(GOALS_F)
    holdings_by_code = {}
    for p in dom.get("positions", []):
        holdings_by_code[p.get("code")] = ("국내", kb._num(p.get("now")))
    for h in ovs.get("holdings", []):
        holdings_by_code[h.get("code")] = ("해외", kb._num(h.get("now")))

    # position_change_pct(K-POP -20% 감시): 기준가 로드 + 대상 종목 현재가 일괄 조회(미보유도, 중복제거)
    kpop_base = {it.get("code"): kb._num(it.get("baseline_price"))
                 for it in _load(ROOT / "memory/kpop_baselines.json").get("items", [])}
    pc_codes = {c.get("code") for c in goals.get("alert_conditions", [])
                if c.get("type") == "position_change_pct" and c.get("code")}
    kpop_now = {}
    for _c in pc_codes:
        kpop_now[_c] = kis_price(token, _c)
        time.sleep(0.25)   # KIS 초당 호출 제한 보호

    for cond in goals.get("alert_conditions", []):
        t = cond.get("type")
        if t == "total_change_pct":
            base = day_open if cond.get("window", "day") == "day" else last_total
            if base <= 0:
                continue
            chg = (total - base) / base * 100
            thr = float(cond["threshold_pct"])
            hit = chg <= thr if thr < 0 else chg >= thr
            if hit and cooldown_ok(cond["id"], cond.get("cooldown_minutes", 120)):
                sign = "📉" if chg < 0 else "📈"
                win = "당일" if cond.get("window", "day") == "day" else "직전"
                slack(f"{sign} 총자산 {chg:+.2f}% ({win}대비) — 현재 {int(total):,}원. {cond.get('note', '')}".strip())
        elif t == "position_target":
            code = cond.get("code")
            target = kb._num(cond.get("target_price"))
            mk = holdings_by_code.get(code)
            if not mk or target <= 0:
                continue
            market, cur = mk
            side = cond.get("side", "above")
            hit = cur >= target if side == "above" else cur <= target
            if hit and cooldown_ok(cond["id"], cond.get("cooldown_minutes", 1440)):
                op = "≥" if side == "above" else "≤"
                slack(f"🎯 {cond.get('name', code)} ({market}) 목표가 도달 — 현재 {cur:,.2f} {op} {target:,.2f}. {cond.get('note', '')}".strip())
        elif t == "position_change_pct":
            code = cond.get("code")
            base = kb._num(cond.get("baseline_price")) or kpop_base.get(code) or 0  # 규칙 자체 기준가 우선(매매규칙), 없으면 K-POP 파일
            cur = kpop_now.get(code) or 0
            if base <= 0 or cur <= 0:
                continue
            chg = (cur - base) / base * 100
            thr = float(cond.get("threshold_pct", -20))
            hit = chg <= thr if thr < 0 else chg >= thr  # 하락(-)·상승(+) 양방향
            if hit and cooldown_ok(cond["id"], cond.get("cooldown_minutes", 1440)):
                icon = "📉" if chg < 0 else "📈"
                head = cond.get("alert_message") or f"{icon} {cond.get('name', code)} {chg:+.1f}% (기준가 대비)"
                lines = [head, f"기준가 {int(base):,}원 → 현재 {int(cur):,}원 ({chg:+.1f}%)."]
                act = cond.get("action") or {}
                if act:
                    sidekr = "매수" if act.get("side") == "buy" else "매도"
                    qty = act.get("qty")
                    amt = kb._num(act.get("amount_krw"))
                    if not qty and amt > 0 and cur > 0:
                        qty = int(amt // cur)  # ~원어치 → 현재가로 수량 환산
                    qty = int(qty or 0)
                    est = int(qty * cur)
                    lines.append(f"⚙️ 준비된 주문: {cond.get('name', code)} {sidekr} {qty}주 (예상 ~{est:,}원, 현재가 기준)")
                    # 자동 체결 안 함. 실행은 본인이 직접 — 기존 승인 게이트(!실거래 → bin/kis-order) 명령을 그대로 제시.
                    lines.append(f"▶️ 실행하려면 본인이 직접 전송: `!실거래 {sidekr} {code} {qty} {int(cur)}`")
                    lines.append("   (지정가=현재가 예시. bin/kis-order가 킬스위치·한도·본인 Slack 승인 확인 후 체결. 시스템 자동 체결 없음.) 또는 KIS 앱에서 직접.")
                else:
                    lines.append("매매 결정은 직접 KIS HTS에서.")
                slack("\n".join(lines))

    st["last_total"] = total
    STATE_F.parent.mkdir(parents=True, exist_ok=True)
    STATE_F.write_text(json.dumps(st, ensure_ascii=False, indent=2), encoding="utf-8")
    print(f"[invest-poll] total={int(total):,} day_open={int(day_open):,} ({today})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
